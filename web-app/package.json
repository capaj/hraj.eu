{
  "name": "hraj.eu",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite dev",
    "build": "pnpm lingui:extract && pnpm lingui:compile && vite build",
    "ci:build": "pnpm run build && pnpm run migrate",
    "start": "vite start",
    "bump": "ncu -u -c 2d",
    "migrate": "drizzle-kit migrate",
    "generate": "drizzle-kit generate",
    "deploy": "pnpm run ci:build && wrangler deploy",
    "wrdeploy": "pnpm run deploy",
    "postinstall": "pnpm run cf-typegen",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv",
    "lingui:extract": "lingui extract",
    "lingui:compile": "lingui compile"
  },
