    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "input-otp": "^1.4.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.24.0",
    "lz-ts": "^1.1.2",
    "offline-geocode-city": "^1.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
