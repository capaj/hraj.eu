    "@libsql/client": "^0.17.2",
    "@lingui/core": "^5.9.5",
    "@lingui/macro": "^5.9.5",
    "@lingui/react": "^5.9.5",
    "@lingui/vite-plugin": "^5.9.5",
    "@paralleldrive/cuid2": "2.2.2",
